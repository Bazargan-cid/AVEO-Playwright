# AVEO-Playwright Configuration
# Copy this file to .env and fill in your values

# Required: Username for login
USERNAME=testuser

# Required: Password for login
PASSWORD=testpass

# Required: Base URL of target website
BASE_URL=file:///path/to/dummy_site/login.html

# Optional: Browser mode (true for headless, false for headed)
HEADLESS=true

# Optional: Timeout in seconds for operations
TIMEOUT=30

# AWS Credentials (REQUIRED - Replace with your actual credentials)
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=us-east-1

# AWS Services Configuration
AWS_DEFAULT_REGION=us-east-1
CLOUDWATCH_NAMESPACE=AVEO-Playwright/NovaAct
CLOUDWATCH_LOG_GROUP=/aws/aveo-playwright/integration

# S3 Configuration
S3_BUCKET_NAME=aveo-playwright-output
S3_REGION=us-east-1
S3_UPLOAD_ENABLED=true

# AWS Bedrock Configuration
BEDROCK_MODEL_ID=amazon.nova-pro-v1:0
BEDROCK_REGION=us-east-1

# Nova Act Configuration (optional)
# NOVA_ACT_API_KEY=your_nova_act_api_key
